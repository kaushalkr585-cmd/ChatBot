{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/nvidia(.*)",
      "destination": "https://integrate.api.nvidia.com/v1$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://chatbot-backend-tau-eight.vercel.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
